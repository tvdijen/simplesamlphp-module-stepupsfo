{
    "name": "openconextapps/simplesamlphp-module-stepupsfo",
    "description": "OpenConext Stepup Second Factor Only Authproc Filter for SimpleSAMLphp",
    "keywords": [ "openconext", "stepup", "sfo", "mfa", "simplesamlphp", "saml" ],
    "homepage": "https://github.com/OpenConextApps/simplesamlphp-module-stepupsfo",
    "license": "LGPL-2.1",
    "type": "simplesamlphp-module",
    "config": {
        "preferred-install": {
            "simplesamlphp/simplesamlphp": "source",
            "*": "dist"
        },
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "simplesamlphp/composer-module-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "simplesamlphp/composer-xmlprovider-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "SimpleSAML\\Module\\stepupsfo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimpleSAML\\Test\\Utils\\": "vendor/simplesamlphp/simplesamlphp/tests/Utils"
        }
    },
    "require": {
        "php": "^8.3",

        "simplesamlphp/simplesamlphp": "~2.5@dev",
        "simplesamlphp/saml2-legacy": "~4.20"
    },
    "require-dev": {
        "simplesamlphp/composer-module-installer": "~1.7",
        "simplesamlphp/simplesamlphp-test-framework": "~1.11"
    },
    "support": {
        "issues": "https://github.com/simplesamlphp/simplesamlphp-module-stepupsfo/issues",
        "source": "https://github.com/simplesamlphp/simplesamlphp-module-stepupsfo"
    }
}
